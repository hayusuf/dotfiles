!dwm.font: xft:DejaVuSansMono:size=10
!st.font: xft:DejaVuSansMono:size=10
!URxvt.boldfont: xft:DejaVuSansMono-Bold:size=10
!Urxvt.italicfont: xft:DejaVuSansMono-Oblique:size=10

!URxvt.scrollBar_right:true
!URxvt.scrollBar:false
!URxvt.cursorBlink: true


st.font:			-*-fixed-*-*-*-*-10-*-*-*-*-*-*-1
st.bold_font:			0

dwm.font:			-*-fixed-*-*-*-*-10-*-*-*-*-*-*-1
dwm.bold_font:			0
st.background:			#131415
st.foreground:			#A3BAD0
st.cursorColor:			#8d9b53
!st.termname:			xterm-256color
st.shell:			/bin/bash
!st.bellvolume:			100
st.tabspaces:			8
!st.chscale:			1.0
!st.cwscale:			1.0

st.alpha:50

!dwm*background:                     #151718
!dwm*foreground:                     #d6d6d6
!dwm*cursorColor:                    #d6d6d6


!st*background:                     #151718
!st*foreground:                     #d6d6d6
!st*cursorColor:                    #d6d6d6

!URxvt*scrollColor:                    #d6d6d6
!URxvt*highlightColor:                 #3B758C
!URxvt*highlightTextColor:             #43a5d5
!URxvt*cursorColor2:                   color
!URxvt*pointerColor:                   color
!URxvt*pointerColor2:                  color
!URxvt*borderColor:                    color
!URxvt*tab-bg:                         color
!URxvt*tab-fg:                         color
!URxvt*tabbar-bg:                      color
!URxvt*tabbar-fg:                      color

