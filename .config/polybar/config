[colors]
background = #000000
background-alt = #758182
foreground = #239199
foreground-alt = #16f8fc
primary = #4d7c7c
secondary = #8c4040

[bar/base]
font-0 = 3270Medium Nerd Font:pixelsize=12;1
font-1 = "FontAwesome5Free:style=Regular:size=12:antialias=true;2"
font-2 = "FontAwesome5Free:style=Solid:size=12:antialias=true;3"
radius = 0
height = 30
background = ${colors.background}
foreground = ${colors.foreground}
override-redirect = true
offset-y = 1%

[bar/main]
inherit = bar/base
width = 5%
modules-left = cpu 

[bar/vol]
inherit = bar/base
width = 5%
offset-x = 10%
modules-left = pulseaudio
cursor-click = pointer
cursor-scroll = ns-resize

[bar/date]
inherit = bar/base
width = 20%
offset-x = 80%
modules-right = date powermenu  

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = " "
format-prefix-foreground = ${colors.foreground-alt}
format-underline = #f90000
label = %percentage:2%%

[module/date]
type = internal/date
interval = 10
date-alt = "%m/%d/20"
time = %I:%M
format-prefix-foreground = ${colors.foreground-alt}
format-underline = #0a6cf5
label = %time% %date%

[module/pulseaudio]
type = internal/pulseaudio
format-volume = <ramp-volume> <label-volume>
label-volume = %percentage%%
use-ui-max = false
interval = 5
ramp-volume-0 = ""
ramp-volume-1 = ""
ramp-volume-2 = ""
label-muted = ""

[module/powermenu]
type = custom/menu
 
format-foreground = ${colors.foreground}
format-background = ${colors.background}
 
label-open = 
label-open-padding = 1
 
label-close = CLOSE
label-close-padding = 1
 
 
menu-0-0 = REBOOT
menu-0-0-exec = reboot
menu-0-0-padding = 1
 
menu-0-1 = SHUTDOWN
menu-0-1-exec = "shutdown now"
menu-0-1-padding = 1

[global/wm]
margin-top = 5
margin-bottom = 5
